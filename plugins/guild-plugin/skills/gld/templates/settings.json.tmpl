{
  "permissions": {
    "allow": [
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash({{TEST_BIN}}:*)",
      "Bash({{LINT_BIN}}:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/guild/gates/scripts/gate_precommit.py\""
          }
        ]
      }
    ]
  }
}
